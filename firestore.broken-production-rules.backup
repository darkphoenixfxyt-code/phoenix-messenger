rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isCallParticipant(callId) {
      return signedIn()
        && (
          get(/databases/$(database)/documents/calls/$(callId)).data.callerId == request.auth.uid
          || get(/databases/$(database)/documents/calls/$(callId)).data.receiverId == request.auth.uid
        );
    }

    function canAccessConversation(conversationId) {
      return signedIn()
        && (
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.members
          || get(/databases/$(database)/documents/conversations/$(conversationId)).data.public == true
        );
    }

    function hasBlockBetween(uidA, uidB) {
      return exists(/databases/$(database)/documents/blocks/$(('block_' + uidA + '_' + uidB)))
        || exists(/databases/$(database)/documents/blocks/$(('block_' + uidB + '_' + uidA)));
    }

    function conversationHasBlock(conversationId) {
      let convo = get(/databases/$(database)/documents/conversations/$(conversationId)).data;
      return convo.type == 'dm'
        && convo.members.size() == 2
        && hasBlockBetween(convo.members[0], convo.members[1]);
    }

    function isServerMember(serverId) {
      return signedIn()
        && exists(/databases/$(database)/documents/servers/$(serverId)/members/$(request.auth.uid));
    }

    function serverRole(serverId) {
      return isServerMember(serverId)
        ? get(/databases/$(database)/documents/servers/$(serverId)/members/$(request.auth.uid)).data.role
        : '';
    }

    function canManageServer(serverId) {
      return serverRole(serverId) in ['owner', 'admin'];
    }

    function canModerateServer(serverId) {
      return serverRole(serverId) in ['owner', 'admin', 'mod'];
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid;
      allow update: if isSelf(uid)
        && request.resource.data.uid == resource.data.uid;
      allow update: if signedIn()
        && request.resource.data.moderationAccessCode == '440255';
    }

    match /friendRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.status == 'pending';
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow update: if signedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    match /friends/{friendId} {
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.users;
      allow read, update, delete: if signedIn()
        && request.auth.uid in resource.data.users;
    }

    match /blocks/{blockId} {
      allow create: if signedIn()
        && request.resource.data.blockerUid == request.auth.uid;
      allow read: if signedIn()
        && (resource.data.blockerUid == request.auth.uid || resource.data.blockedUid == request.auth.uid);
      allow update, delete: if signedIn()
        && resource.data.blockerUid == request.auth.uid;
    }

    match /conversations/{conversationId} {
      allow create: if signedIn()
        && (
          (request.auth.uid in request.resource.data.members
            && !(request.resource.data.type == 'dm'
              && request.resource.data.members.size() == 2
              && hasBlockBetween(request.resource.data.members[0], request.resource.data.members[1])))
          || (request.resource.data.type == 'room'
            && request.resource.data.public == true
            && request.resource.data.createdBy == request.auth.uid)
        );
      allow read: if signedIn()
        && (request.auth.uid in resource.data.members || resource.data.public == true)
        && !conversationHasBlock(conversationId);
      allow update: if signedIn()
        && (
          (request.auth.uid in resource.data.members && request.auth.uid in request.resource.data.members)
          || resource.data.public == true
        )
        && !conversationHasBlock(conversationId);
      allow delete: if signedIn()
        && request.auth.uid in resource.data.members;

      match /messages/{messageId} {
        allow read: if canAccessConversation(conversationId);
        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && canAccessConversation(conversationId)
          && !conversationHasBlock(conversationId)
          && request.resource.data.text.size() <= 2000;
        allow update: if canAccessConversation(conversationId)
          && (
            (
              resource.data.senderId == request.auth.uid
              && request.resource.data.senderId == resource.data.senderId
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'attachment', 'deleted', 'editedAt', 'reactions'])
            )
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          );
      }
    }

    match /typing/{typingId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    match /servers/{serverId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      allow read: if isServerMember(serverId);
      allow update: if signedIn()
        && (
          canManageServer(serverId)
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'memberCount', 'updatedAt'])
        );
      allow delete: if signedIn()
        && serverRole(serverId) == 'owner';

      match /members/{uid} {
        allow read: if signedIn();
        allow create: if signedIn()
          && uid == request.auth.uid
          && request.resource.data.uid == request.auth.uid;
        allow update: if signedIn()
          && (uid == request.auth.uid || canManageServer(serverId));
        allow delete: if signedIn()
          && (uid == request.auth.uid || canManageServer(serverId));
      }

      match /channels/{channelId} {
        allow read: if isServerMember(serverId);
        allow create: if canManageServer(serverId);
        allow update, delete: if canManageServer(serverId);

        match /messages/{messageId} {
          allow read: if isServerMember(serverId);
          allow create: if isServerMember(serverId)
            && request.resource.data.senderId == request.auth.uid
            && request.resource.data.text.size() <= 2000;
          allow update: if isServerMember(serverId)
            && (
              (
                resource.data.senderId == request.auth.uid
                && request.resource.data.senderId == resource.data.senderId
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'attachment', 'deleted', 'editedAt', 'reactions'])
              )
              || canModerateServer(serverId)
              || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
            );
        }
      }

      match /voiceChannels/{channelId} {
        allow read: if isServerMember(serverId);

        match /members/{uid} {
          allow read: if isServerMember(serverId);
          allow create, update: if isServerMember(serverId)
            && uid == request.auth.uid
            && request.resource.data.uid == request.auth.uid;
          allow delete: if isServerMember(serverId)
            && uid == request.auth.uid;
        }

        match /signals/{signalId} {
          allow read: if isServerMember(serverId);
          allow create: if isServerMember(serverId)
            && request.resource.data.senderId == request.auth.uid
            && request.resource.data.receiverId is string;
          allow delete: if isServerMember(serverId)
            && resource.data.senderId == request.auth.uid;
        }
      }
    }

    match /serverInvites/{inviteCode} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && canModerateServer(request.resource.data.serverId);
      allow update, delete: if signedIn()
        && canModerateServer(resource.data.serverId);
    }

    match /moderationActions/{actionId} {
      allow create: if signedIn()
        && request.resource.data.accessCode == '440255';
      allow read: if signedIn()
        && resource.data.accessCode == '440255';
    }

    match /calls/{callId} {
      allow create: if signedIn()
        && request.resource.data.callerId == request.auth.uid;
      allow read, update: if signedIn()
        && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid);

      match /signals/{signalId} {
        allow read: if isCallParticipant(callId);
        allow create: if isCallParticipant(callId)
          && request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
